me main{flex:1;justify-content:center;align-items:center;padding:48px 20px;display:flex}.hero{text-align:center;width:100%;max-width:640px}.hero h1{letter-spacing:-.01em;color:var(--text);margin:0 0 18px;font-size:clamp(26px,5vw,38px);font-weight:700;line-height:1.25}.hero p{color:var(--muted);margin:0 0 32px;font-size:clamp(15px,2.5vw,17px)}.cta{background:var(--primary);border-radius:var(--radius);cursor:pointer;box-shadow:var(--shadow-md);text-align:center;border:none;width:100%;max-width:420px;padding:18px 32px;font-size:17px;font-weight:600;transition:background-color .15s,transform .15s;display:inline-block;color:#fff!important}.cta:hover{background:var(--primary-hover);text-decoration:none;transform:translateY(-1px)}.cta:active{transform:translateY(0)}.cta:focus-visible{outline-offset:3px;outline:3px solid #93c5fd}.site-header{border-bottom:1px solid var(--border);background:#fff}.site-header .wrap{flex-wrap:wrap;justify-content:space-between;align-items:center;gap:16px;max-width:1100px;margin:0 auto;padding:16px 20px;display:flex}.brand{color:var(--text);align-items:center;gap:10px;font-weight:700;display:flex}.brand-logo{background:var(--primary);color:#fff;border-radius:8px;justify-content:center;align-items:center;width:32px;height:32px;font-size:14px;font-weight:700;display:inline-flex}.site-nav{flex-wrap:wrap;gap:20px;display:flex}.site-nav a{color:var(--muted);font-size:14px}.site-nav a:hover{color:var(--text);text-decoration:none}.site-footer{background:var(--surface);border-top:1px solid var(--border);color:var(--muted);margin-top:64px;font-size:14px}.site-footer .wrap{max-width:1100px;margin:0 auto;padding:40px 20px 24px}.footer-grid{grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:28px;display:grid}.footer-grid h4{color:var(--text);text-transform:uppercase;letter-spacing:.04em;margin:0 0 12px;font-size:14px}.footer-grid ul{margin:0;padding:0;list-style:none}.footer-grid li{margin-bottom:8px}.footer-grid a{color:var(--muted)}.footer-grid